# Frontend API base URL. Leave as /api for Vite proxy in local development.
VITE_API_URL=/api

# Dev server binding (what Vite listens on). Default is safe local-only.
# For Tailscale access, prefer the host machine's Tailscale IP.
# You can also run `./start.sh --tailscale` from the repo root to detect it.
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173

# Optional display override shown in Settings for Private App URL.
# If blank, Settings will infer from VITE_DEV_HOST when it is Tailscale-specific
# (and not localhost/127.0.0.1/0.0.0.0).
# Example: <TAILSCALE_IP> or your-host.your-tailnet.ts.net
VITE_PRIVATE_APP_HOST=

# Optional: explicit private API URL shown in Settings (example: http://<TAILSCALE_IP>:3001)
VITE_PRIVATE_API_URL=

# Vite proxy target for /api in dev.
# If the API is bound to a Tailscale IP, set this to http://<TAILSCALE_IP>:3001.
VITE_API_PROXY_TARGET=http://127.0.0.1:3001
