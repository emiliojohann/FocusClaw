PORT=3001
API_HOST=127.0.0.1
NODE_ENV=development

# For Tailscale access, prefer binding to the host machine's Tailscale IP.
# You can also run `./start.sh --tailscale` from the repo root to detect it.
# API_HOST=<TAILSCALE_IP>

# Database (local SQLite file, relative to apps/api when running npm scripts)
# start.sh sets this to an absolute path at <repo>/data/focusclaw.db.
DATABASE_URL=sqlite:../../data/focusclaw.db

# API Key - change this to a random string.
# If unset, auth is disabled for local-only development.
API_KEY=dev-api-key

# Optional CORS override (comma-separated origins).
# Keep this unset for local-only defaults.
# Example for Tailscale access:
# CORS_ORIGINS=http://<TAILSCALE_IP>:5173,http://localhost:5173
# CORS_ORIGINS=https://your-host.your-tailnet.ts.net:8443,http://localhost:5173
